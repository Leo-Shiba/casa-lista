# Chave secreta para assinar os tokens JWT (use algo longo e aleatório em produção)
JWT_SECRET=troque-por-uma-chave-secreta-longa

# Porta (a Square Cloud injeta sozinha; localmente usa 3000)
PORT=3000

# ---- FASE 2: Mercado Livre (preencher depois de criar o app no painel de devs) ----
ML_CLIENT_ID=
ML_CLIENT_SECRET=
ML_REDIRECT_URI=
ML_REFRESH_TOKEN=

# ---- FASE 2: Shopee (preencher quando a credencial de afiliado chegar) ----
SHOPEE_APP_ID=
SHOPEE_SECRET=
